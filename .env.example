# Environment Variables for X Reply Bot

# X Auth Cookies
# Get these by opening x.com in your browser, F12 -> Application -> Cookies
X_AUTH_TOKEN=your_auth_token_here
X_CT0=your_ct0_here

# Your X handle (without @)
OUR_USERNAME=your_username_here

# The account you want to mimic
TARGET_INFLUENCER_USERNAME=target_influencer_here

# OpenAI API Key for generating replies
OPENAI_API_KEY=sk-xxxx...

# Daily Limit for replies (default: 20)
MAX_REPLIES_PER_DAY=20

# Daily Limit for engagement posts (default: 3)
MAX_ENG_POSTS_PER_DAY=3

# Daily Limit for image posts (default: 1)
MAX_IMG_POSTS_PER_DAY=1

# Preferred language for replies (default: English)
REPLY_LANGUAGE=English
